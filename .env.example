# ============================================================
#  Cesar OS Platform — Fase 0 — plantilla de entorno
#  Copia a .env y rellena. NUNCA subas .env a git (ya está en .gitignore).
#  Genera secretos con:   openssl rand -hex 32
# ============================================================

# --- Dominio (apunta los DNS A: @, llm, observ -> IP del VPS) ---
DOMAIN=cesaros.tudominio.com

# --- Llaves LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENROUTER_API_KEY=sk-or-xxxxx
GROQ_API_KEY=gsk_xxxxx

# --- LiteLLM ---
LITELLM_MASTER_KEY=sk-litellm-genera-uno-largo-aleatorio

# --- Postgres ---
POSTGRES_USER=cesaros
POSTGRES_PASSWORD=cambia-esto-por-uno-fuerte
POSTGRES_DB=cesaros

# --- Langfuse (genera cada uno con: openssl rand -hex 32) ---
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SALT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Langfuse keys: se generan en su UI tras el 1er login; pégalas aquí y reinicia litellm ---
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxx
